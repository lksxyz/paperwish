{
  "name": "mediapipe-object-detection",
  "version": "0.1.0",
  "description": "Browser-based real-time object detection using MediaPipe Tasks Vision and Parcel",
  "source": "index.html",
  "scripts": {
    "start": "parcel --port 1234",
    "build": "parcel build --no-source-maps --public-url ./",
    "clean": "rm -rf dist .parcel-cache"
  },
  "browserslist": "> 0.5%, last 2 versions, not dead",
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.18"
  },
  "devDependencies": {
    "parcel": "^2.12.0"
  }
}
